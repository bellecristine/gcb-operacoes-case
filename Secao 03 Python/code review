from typing import Any
import logging

logger = logging.getLogger(__name__)

TAXAS_POR_CLASSE: dict[str, float] = {
    "DEB": 1.12,
    "CRI": 1.10,
    "CRA": 1.09,
}


def aplicar_taxa(lista: list[dict[str, Any]]) -> list[float]:
    """
    Aplica taxa de rendimento sobre o valor de cada item.

    Itens com classe desconhecida mantêm o valor original.
    Itens com campos ausentes ou inválidos são ignorados com log.

    Args:
        lista: lista de dicts com chaves 'classe' e 'valor'

    Returns:
        lista de valores com taxa aplicada
    """
    resultado = []

    for i, item in enumerate(lista):
        try:
            valor = float(item["valor"])
            classe = item.get("classe", "").upper()
            taxa = TAXAS_POR_CLASSE.get(classe, 1.0)

            if classe and classe not in TAXAS_POR_CLASSE:
                logger.warning(
                    f"Item {i}: classe '{classe}' não mapeada. "
                    f"Mantendo valor original."
                )

            resultado.append(round(valor * taxa, 2))

        except (KeyError, TypeError, ValueError) as e:
            logger.error(f"Item {i} ignorado por erro: {item} — {e}")

    return resultado